# Bybit API Keys
# https://www.bybit.com/app/user/api-management 에서 발급
BYBIT_API_KEY=your_api_key_here
BYBIT_API_SECRET=your_api_secret_here

# 테스트넷 여부 (true = 테스트넷, false = 실거래)
TESTNET=true

# 거래 설정
SYMBOL=BTCUSDT
# ⚠️ 레버리지는 낮게. 20x는 손절 전에 강제청산될 수 있습니다(권장 3~5x).
LEVERAGE=5
# ⚠️ 1회 리스크. 1~2% 권장. 5% 초과 시 봇이 시작을 거부합니다.
RISK_PCT=0.02

# 안전장치 (없으면 기본값 사용)
MAX_CONSECUTIVE_LOSSES=3      # 연속 N회 손절 시 당일 신규 진입 정지
DAILY_LOSS_LIMIT_PCT=0.06     # 하루 누적 -6% 도달 시 당일 진입 정지
COOLDOWN_AFTER_LOSS_MIN=30    # 손절 직후 N분간 신규 진입 보류

# 상태 저장 파일 (재시작 시 포지션/카운터 복구). 클라우드는 볼륨 마운트 권장.
STATE_FILE=bot_state.json

# 클라우드 배포 시 로그 레벨 (DEBUG / INFO / WARNING)
LOG_LEVEL=INFO

# ─── 텔레그램 알림 (코인봇·폭등스캐너 공용) ───
# 없으면 알림 미발송. @BotFather로 봇 생성 → 토큰, 챗ID는 @userinfobot으로 확인
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ─── 한국주식 돌파 감지 (외부 hanto-sear 스캐너 API) ───
HANTO_SEAR_URL=

# ─── 폭등 임박 일일 스캐너 (surge) ───
# true로 켜면 매일 장마감 후 전종목 스캔 → 텔레그램 알림. 기본 false (검증 후 의식적 투입).
# ⚠️ 발굴 알림일 뿐 자동매매 아님. 투자 판단·책임은 본인.
SURGE_ENABLED=false
SURGE_SCAN_HOUR=16        # 장마감(15:30) 후 스캔 시각 (KST, 정시)
SURGE_CACHE_DIR=data      # 일봉 캐시 디렉토리
